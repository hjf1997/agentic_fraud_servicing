# LLM provider: 'bedrock' (Claude via AWS) or 'openai' (GPT via OpenAI API)
LLM_PROVIDER=bedrock

# AWS credentials profile for Bedrock access
AWS_PROFILE=default

# AWS region for Bedrock endpoint
AWS_REGION=us-east-1

# Bedrock model identifier
AWS_BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# OpenAI API key (required only when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here

# LangFuse observability (optional — disabled if keys not set)
# Cloud: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US)
# Self-hosted: http://localhost:3000
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
