# LLM provider
LLM_PROVIDER=connectchain

# ConnectChain settings
CONNECTCHAIN_MODEL_INDEX=0
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_USE_RESPONSES_API=false

# LangFuse observability (optional — disabled if keys not set)
# Cloud: https://cloud.langfuse.com (EU) or https://us.cloud.langfuse.com (US)
# Self-hosted: http://localhost:3000
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=pk-lf-your-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-key-here
